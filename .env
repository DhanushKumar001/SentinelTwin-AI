# SentinelTwin AI — Environment Configuration

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
LOG_LEVEL=info

# Simulation
SIMULATION_TICK_INTERVAL=2.0
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Factory Machines
MACHINE_COUNT=5
FACTORY_NAME=SentinelTwin Smart Factory

# Thresholds
TEMP_WARNING_THRESHOLD=75.0
TEMP_CRITICAL_THRESHOLD=90.0
VIBRATION_WARNING_THRESHOLD=7.0
VIBRATION_CRITICAL_THRESHOLD=10.0
CURRENT_WARNING_THRESHOLD=80.0
CURRENT_CRITICAL_THRESHOLD=95.0

# AI Module Settings
PREDICTIVE_WINDOW_SIZE=50
ANOMALY_SENSITIVITY=0.85
DEFECT_DETECTION_CONFIDENCE=0.75

# Scenario Settings
AUTO_SELF_HEAL=true
SELF_HEAL_DELAY_SECONDS=15
SCENARIO_AUTO_RESOLVE=true
SCENARIO_RESOLVE_SECONDS=30
